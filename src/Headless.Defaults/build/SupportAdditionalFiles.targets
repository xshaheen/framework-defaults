<Project>
  <PropertyGroup>
    <HeadlessCopyEditorConfigToSolutionDir Condition="'$(HeadlessCopyEditorConfigToSolutionDir)' == ''"
      >false</HeadlessCopyEditorConfigToSolutionDir
    >
  </PropertyGroup>

  <Target
    Condition="'$(HeadlessCopyEditorConfigToSolutionDir)' == 'true'
      and '$(SolutionDir)' != ''
      and $(SolutionDir) != '*Undefined*'"
    Name="UpdateEditorConfig"
    BeforeTargets="Build"
  >
    <Copy
      SourceFiles="$(MSBuildThisFileDirectory)../configurations/editorconfig.txt"
      DestinationFiles="$(SolutionDir).editorconfig"
      SkipUnchangedFiles="true"
    />
  </Target>
</Project>
